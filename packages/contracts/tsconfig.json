{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "include": ["hardhat.config.ts", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "artifacts", "cache", "dist"]
}
