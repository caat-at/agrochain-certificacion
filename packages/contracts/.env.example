# =============================================
# AgroChain Contracts — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env al repositorio
# =============================================

# Clave privada del deployer
# NUNCA uses tu wallet principal — usa una wallet dedicada solo para deploys
DEPLOYER_PRIVATE_KEY=0xTU_CLAVE_PRIVADA_DEPLOYER_AQUI

# RPCs
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
POLYGON_MAINNET_RPC=https://polygon-rpc.com

# PolygonScan — para verificar contratos (https://polygonscan.com/myapikey)
POLYGONSCAN_API_KEY=TU_API_KEY_POLYGONSCAN_AQUI
