# =============================================================================
# AGROCHAIN - Variables de Entorno
# Copiar este archivo a .env y completar los valores
# =============================================================================

# ── BASE DE DATOS TURSO ───────────────────────────────────────────────────────
# Para desarrollo local (SQLite sin Turso):
DATABASE_URL="file:./dev.db"

# Para Turso en nube (staging/produccion):
# DATABASE_URL="libsql://agrochain-<tu-org>.turso.io"
# DATABASE_AUTH_TOKEN="tu-token-turso"

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=cambiar-por-secreto-seguro-minimo-32-chars
CORS_ORIGIN=http://localhost:3000

# ── IPFS (Pinata) ─────────────────────────────────────────────────────────────
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# ── POLYGON BLOCKCHAIN ────────────────────────────────────────────────────────
# Usar Amoy testnet para desarrollo
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_CHAIN_ID=80002

# Wallet del backend (firma transacciones - NO exponer en cliente)
BACKEND_WALLET_PRIVATE_KEY=

# Direcciones de contratos desplegados (se llenan despues del deploy)
CONTRACT_LOTE_REGISTRY=
CONTRACT_CERTIFICADO_NFT=
CONTRACT_ROLE_MANAGER=
