# =============================================
# AgroChain API — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env al repositorio
# =============================================

# Base de datos (desarrollo local SQLite o Turso cloud)
DATABASE_URL="file:../../packages/database/dev.db"
DATABASE_AUTH_TOKEN=

# Servidor
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT — Cambia este valor en producción por uno seguro
JWT_SECRET=CAMBIA_ESTE_VALOR_EN_PRODUCCION

# IPFS — Pinata (https://app.pinata.cloud)
PINATA_JWT=TU_PINATA_JWT_AQUI

# Blockchain — Polygon Amoy testnet
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_CHAIN_ID=80002

# Wallet del backend para firmar transacciones
# NUNCA uses tu wallet principal — crea una wallet dedicada solo para este servicio
BACKEND_WALLET_PRIVATE_KEY=0xTU_CLAVE_PRIVADA_AQUI

# Direcciones de contratos desplegados (se generan al hacer deploy)
CONTRACT_LOTE_REGISTRY=0x
CONTRACT_CERTIFICADO_NFT=0x
CONTRACT_ROLE_MANAGER=0x
