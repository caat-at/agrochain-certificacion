{
  "name": "agrochain",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @agrochain/database db:push",
    "db:migrate": "pnpm --filter @agrochain/database db:migrate",
    "db:seed": "pnpm --filter @agrochain/database db:seed",
    "db:studio": "pnpm --filter @agrochain/database db:studio",
    "db:generate": "pnpm --filter @agrochain/database db:generate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.0"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
